# ============================================================
#  GAMEVAULT - Plantilla de variables de entorno
#  Copia este archivo a ".env" y rellena con valores reales.
#  ¡NUNCA subas el archivo .env a GitHub!
# ============================================================

# --- Base de datos ---
POSTGRES_DB=gamevault
POSTGRES_USER=tu_usuario_db
POSTGRES_PASSWORD=tu_password_db

SPRING_DATASOURCE_URL=jdbc:postgresql://database:5432/gamevault
SPRING_DATASOURCE_USERNAME=tu_usuario_db
SPRING_DATASOURCE_PASSWORD=tu_password_db

# --- JWT ---
# Genera una clave segura con: openssl rand -base64 64
JWT_SECRET=CAMBIA_ESTO_por_una_clave_generada_con_openssl
JWT_EXPIRATION=86400000

# --- API RAWG.IO ---
# Consigue tu clave en: https://rawg.io/apidocs
RAWG_API_KEY=CAMBIA_ESTO_por_tu_api_key_de_rawg
